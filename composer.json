{
    "name": "semitexa/cache",
    "description": "Application-level cache package for Semitexa \u2014 key-value store, tenant namespacing, tag invalidation",
    "version": "1.0.0",
    "type": "semitexa-module",
    "license": "MIT",
    "authors": [
        {
            "name": "Semitexa",
            "email": "support@semitexa.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "semitexa/core": "^1.0",
        "predis/predis": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Semitexa\\Cache\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Semitexa\\Cache\\Tests\\": "tests/"
        }
    },
    "keywords": [
        "semitexa",
        "cache",
        "redis",
        "tags",
        "tenancy"
    ]
}
